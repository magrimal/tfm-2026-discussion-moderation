# Configuración del servidor — idril.fdi.ucm.es
#
# Copia este fichero a .env.local en la raíz del repo en el servidor y
# rellena los valores marcados con <...>.

# Requerido: ignorado por Ollama pero debe estar presente.
LLM_API_KEY=ollama

# Servidor Ollama compartido del contenedor.
OLLAMA_HOST=http://10.100.0.1:11434

# nginx strips the /api prefix before forwarding to uvicorn, so the API
# must be mounted at / on the server. Default is /api (for local dev).
FACILITATION_API_PREFIX=

# Modelo por defecto para la facilitación en vivo.
# Modelos disponibles en el servidor Ollama compartido:
#   ollama:ministral-3:8b   (8.9B, rápido)
#   ollama:ministral-3:14b  (13.9B, recomendado)
#   ollama:qwen3.5:9b       (9.7B)
#   ollama:qwen3.5:27b      (27.8B, mayor calidad, más lento)
FACILITATION_LLM_MODEL=ollama:ministral-3:14b

# Timeout del pipeline en segundos. Aumentar para modelos grandes.
FACILITATION_PIPELINE_TIMEOUT_SECONDS=180

# Integración con el LMS (Open edX)
FACILITATION_LMS_BACKEND=openedx
FACILITATION_LMS_URL=<URL de la instancia Open edX>
LMS_JWT_AUTHENTICATION_TOKEN=<token JWT emitido por el LMS>

# Opcional: ID de usuario del foro para publicar comentarios de facilitación.
# Si está vacío, el pipeline se ejecuta pero no publica (modo dry-run).
# FACILITATION_BOT_USER_ID=

# Persistencia del historial de intervenciones entre reinicios del servicio.
FACILITATION_HISTORY_BACKEND=sqlite
FACILITATION_HISTORY_DB_PATH=/home/2526-moderacion/app/history.db

# Observabilidad con Logfire (opcional pero recomendado).
LOGFIRE_TOKEN=<token de logfire.pydantic.dev>

# HTTP Basic Auth para el dashboard y la API. Con contraseña vacía la
# autenticación queda deshabilitada por completo — este es un servidor
# público, así que es obligatorio configurarla.
FACILITATION_ADMIN_USERNAME=admin
FACILITATION_ADMIN_PASSWORD=<contraseña generada, ver gestor de secretos>

# Modelos a comparar en las ejecuciones de evaluación desde el dashboard.
EVAL_MODELS=ollama:ministral-3:14b,ollama:qwen3.5:27b

# Almacenamiento de resultados de evaluación en S3 (ver ADR 0044).
# idril es bare-metal, sin rol IAM: requiere access key explícita del
# usuario IAM "facilitation-s3" (permisos limitados a runs/* en el bucket).
AWS_ACCESS_KEY_ID=<access key de facilitation-s3>
AWS_SECRET_ACCESS_KEY=<secret key de facilitation-s3>
FACILITATION_RUN_RESULTS_BACKEND=s3
FACILITATION_S3_BUCKET=tfm-2026-discussion-moderation
FACILITATION_S3_PREFIX=runs
FACILITATION_ENV=idril
