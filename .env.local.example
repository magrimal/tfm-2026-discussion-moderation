# Local development configuration — Ollama
#
# Copy this file to .env.local and adjust as needed.
# Run experiments with:
#   uv run --env-file .env.local eval-models
#
# Run the playground with:
#   uv run --env-file .env.local facilitate docs/playground-example.json
#
# Requires Ollama running locally:
#   curl -fsSL https://ollama.com/install.sh | sh
#   ollama pull qwen2.5:14b      # 14B, Qwen family — confirmed 6/6
#   ollama pull phi4             # 14B, Microsoft — 5/6 (fails at role node: function tools)
#   ollama pull mistral-nemo:12b # 12B, newer Mistral architecture — untested
#   ollama pull gemma2:9b        # 9B, Google — untested
#   ollama pull llama3.1:8b      # 8B, Meta — untested
#   # Gemma 4 MoE via unsloth (26B total / 4B active, Q4_K_M):
#   ollama pull hf.co/unsloth/gemma-4-26B-A4B-it-GGUF:UD-Q4_K_M

# No API key needed for Ollama; the value is ignored but must be set.
LLM_API_KEY=ollama

# Default model for the playground and pipeline.
FACILITATION_LLM_MODEL=ollama:qwen2.5:14b

# Use the stub backend (no live LMS needed for local runs).
FACILITATION_LMS_BACKEND=stub

# Optional label appended to the results directory name.
# EVAL_NAME=prompted-output

# Models to compare in eval-models (comma-separated).
# All must be pulled with `ollama pull <name>` before running.
EVAL_MODELS=ollama:hf.co/unsloth/gemma-4-26B-A4B-it-GGUF:UD-Q4_K_M,ollama:qwen2.5:14b,ollama:mistral-nemo:12b,ollama:llama3.1:8b,ollama:gemma2:9b,ollama:phi4

# Optional per-agent overrides. Uncomment to use a different model
# for a specific pipeline stage.
# FACILITATION_CLASSIFICATION_MODEL=ollama:llama3.1:8b
# FACILITATION_INTERVENTION_MODEL=ollama:llama3.1:8b
# FACILITATION_ORCHESTRATOR_MODEL=ollama:llama3.1:8b
# FACILITATION_ROLE_MODEL=ollama:qwen2.5:14b
