# Local development configuration — Ollama
#
# Copy this file to .env.local and adjust as needed.
# Run experiments with:
#   uv run --env-file .env.local eval-models
#
# Run the playground with:
#   uv run --env-file .env.local facilitate docs/playground-example.json
#
# Requires Ollama running locally:
#   curl -fsSL https://ollama.com/install.sh | sh
#
#   Tool-capable models (full pipeline compatibility):
#   ollama pull qwen2.5:14b      # 14B, Qwen family — 6/6
#   ollama pull mistral-nemo:12b # 12B, Mistral — 6/6
#   ollama pull llama3.1:8b      # 8B, Meta — 6/6 (tool support added in 3.1)
#   ollama pull deepseek-r1:14b  # 14B, DeepSeek reasoning model — pending
#   ollama pull gemma3:12b       # 12B, Google — pending
#
#   Partial compatibility (no tool support, fails at role node):
#   ollama pull phi4             # 14B, Microsoft — 5/6
#   ollama pull gemma2:9b        # 9B, Google — 4/6
#
#   No compatibility (too small to follow output schema):
#   ollama pull gemma3:4b        # 4B — 0/6
#   ollama pull llama3.2         # 3B — 0/6
#   ollama pull mistral          # 7B — 0/6

# Optional: Logfire token for pipeline observability. If set, all agent
# runs emit OpenTelemetry spans to logfire-eu.pydantic.dev.
# Obtain from: https://logfire.pydantic.dev — run `uv run logfire auth` first.
# LOGFIRE_TOKEN=pylf_v1_...

# No API key needed for Ollama; the value is ignored but must be set.
LLM_API_KEY=ollama

# Local API port used by make serve and make dev-up. The dashboard calls this port directly.
DISCUSSION_MODERATION_API_PORT=8765

# Dashboard authentication (HTTP Basic Auth).
# Leave FACILITATION_ADMIN_PASSWORD unset or empty to disable auth (local dev default).
# Set a password in .env.ec2 to protect the dashboard on public deployments.
# FACILITATION_ADMIN_USERNAME=admin
# FACILITATION_ADMIN_PASSWORD=

# Default model for the playground and pipeline.
FACILITATION_LLM_MODEL=ollama:qwen2.5:14b

# Use the stub backend (no live LMS needed for local runs).
FACILITATION_LMS_BACKEND=stub

# Optional label appended to the results directory name.
# EVAL_NAME=prompted-output

# Models to compare in eval-models (comma-separated).
# All must be pulled with `ollama pull <name>` before running.
# Only include tool-capable models — others fail at the role agent node.
EVAL_MODELS=ollama:qwen2.5:14b,ollama:mistral-nemo:12b,ollama:llama3.1:8b,ollama:deepseek-r1:14b,ollama:gemma3:12b

# Optional per-agent overrides. Uncomment to use a different model
# for a specific pipeline stage.
# FACILITATION_CLASSIFICATION_MODEL=ollama:llama3.1:8b
# FACILITATION_INTERVENTION_MODEL=ollama:llama3.1:8b
# FACILITATION_ORCHESTRATOR_MODEL=ollama:llama3.1:8b
# FACILITATION_ROLE_MODEL=ollama:qwen2.5:14b

# S3 run storage (optional). Leave unset to use local filesystem.
# FACILITATION_RUN_RESULTS_BACKEND=s3
# FACILITATION_S3_BUCKET=
# FACILITATION_S3_PREFIX=runs
# FACILITATION_ENV=local
